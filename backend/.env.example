# Сервер
PORT=3001

# База данных PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=АКТИВ_db
DB_USER=postgres
DB_PASSWORD=your_password_here

# JWT (замени на случайную строку 32+ символа)
JWT_SECRET=change_me_to_random_secret_string_32chars
JWT_EXPIRES_IN=7d

# URL фронтенда (для CORS)
FRONTEND_URL=http://localhost:3000

# Окружение: development | production
NODE_ENV=development
